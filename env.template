# Copy this to .env and fill in your values
# Never commit .env to git

# Azure OpenAI — your existing HealthEdge credentials
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_URL=https://your-endpoint.openai.azure.com/openai/deployments/gpt4o_11_2024/chat/completions?api-version=2024-08-01-preview
AZURE_OPENAI_MODEL=gpt-4o

# Embedding model — local path
EMBEDDING_MODEL_PATH=all-MiniLM-L6-v2

# Cost controls
LLM_TIMEOUT_SECONDS=30
MAX_COST_PER_REQUEST_USD=0.05
DAILY_BUDGET_USD=10.0

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Airflow
AIRFLOW_API_URL=http://localhost:8080/api/v1

# Drift
DRIFT_THRESHOLD=0.10

# Paths
COST_LOG_PATH=logs/cost_log.jsonl
LOG_DIR=logs
PROMPTS_DIR=prompts
LATEST_PDF_PATH=data/latest.pdf

OTEL_SDK_DISABLED=true